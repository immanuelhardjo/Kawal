NODE_ENV=development
PORT=3000

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kawal

# Session
SESSION_COOKIE_NAME=kawal_session
SESSION_INACTIVITY_DAYS=30
SESSION_SECRET=replace-with-32-byte-random-hex

# Google OIDC
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Web origin (CORS, sign-in redirect target)
WEB_ORIGIN=http://localhost:5173

# Gemini
GEMINI_API_KEY=

# Ingest
INGEST_REQUEST_CEILING_MS=120000
INGEST_RATE_PER_PUBLISHER_PER_SECOND=1
INGEST_EXCERPT_MAX_CHARS=500

# Logging
LOG_LEVEL=info
